// Fragment: Personal agent config (template)
{
  "id": "personal-{{NOMBRE_SLUG}}",
  "name": "Personal {{NOMBRE}}",
  "workspace": "./workspace-personal-{{NOMBRE_SLUG}}",
  "model": "openrouter/google/gemini-3-flash-preview",
  "heartbeat": {
    "every": "30m",
    "target": "telegram",
    "activeHours": { "start": "{{HORARIO_INICIO}}", "end": "{{HORARIO_FIN}}", "timezone": "{{TIMEZONE}}" },
    "lightContext": true
  }
}
