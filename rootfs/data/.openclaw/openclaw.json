{
  "agents": {
    "list": [
      {
        "id": "implementador",
        "name": "AIOS Implementador",
        "default": true,
        "workspace": "./workspace-implementador",
        "model": "openrouter/google/gemini-3-flash-preview",
        "heartbeat": {
          "every": "4h",
          "target": "slack",
          "activeHours": { "start": "08:00", "end": "22:00", "timezone": "UTC" },
          "lightContext": true
        }
      }
    ]
  },
  "channels": {
    "slack": { "enabled": true }
  },
  "commands": { "text": true, "native": "auto", "config": true },
  "session": { "dmScope": "per-channel-peer" }
}
